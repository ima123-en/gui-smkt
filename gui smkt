local function Track(c) table.insert(Sys.Conns, c); return c end

getgenv().SMKT_DISABLE = function()
    for _, c in pairs(Sys.Conns) do pcall(function() c:Disconnect() end) end
    Sys.Conns = {}
    if CoreGui:FindFirstChild("SMKTHub") then CoreGui.SMKTHub:Destroy() end
end

local function cleanChar()
    local c = LocalPlayer.Character
    if not c then return end
    for _, d in pairs(c:GetDescendants()) do
        if d:IsA("BallSocketConstraint") or d:IsA("NoCollisionConstraint") or d:IsA("HingeConstraint") then 
            pcall(function() d:Destroy() end)
        elseif d:IsA("BodyVelocity") or d:IsA("BodyPosition") or d:IsA("BodyGyro") then 
            pcall(function() d:Destroy() end)
        elseif d:IsA("Motor6D") then 
            pcall(function() d.Enabled = true end) 
        end
    end
end

local function shouldBlock(h)
    local s = h:GetState()
    return s == Enum.HumanoidStateType.Physics or s == Enum.HumanoidStateType.Ragdoll or s == Enum.HumanoidStateType.FallingDown
end

Track(RunService.Stepped:Connect(function()
    if not Sys.AR then return end
    local c = LocalPlayer.Character
    local h = c and c:FindFirstChild("Humanoid")
    if h and shouldBlock(h) then
        pcall(function() h:ChangeState(Enum.HumanoidStateType.Running) end)
        cleanChar()
    end
end))

local isJmp, lastVel = false, Vector3.zero
Track(RunService.Heartbeat:Connect(function()
    if not Sys.AK then return end
    local c = LocalPlayer.Character
    local hrp = c and c:FindFirstChild("HumanoidRootPart")
    local h = c and c:FindFirstChild("Humanoid")
    if not hrp or not h then return end
    
    local st = h:GetState()
    local curV = hrp.AssemblyLinearVelocity
    
    if st == Enum.HumanoidStateType.Jumping then 
        isJmp = true; lastVel = curV return
    elseif st == Enum.HumanoidStateType.Landed or st == Enum.HumanoidStateType.Running then 
        isJmp = false 
    end
    
    local nV = curV
    local changed = false
    local flatV = Vector3.new(curV.X, 0, curV.Z)
    
    if flatV.Magnitude > 60 then
        local u = flatV.Unit
        nV = Vector3.new(u.X * 60, nV.Y, u.Z * 60)
        changed = true
    end
    if not isJmp and st ~= Enum.HumanoidStateType.Freefall and curV.Y > 50 then
        nV = Vector3.new(nV.X, 50, nV.Z)
        changed = true
    end
    if st == Enum.HumanoidStateType.Freefall and not isJmp and (curV.Y - lastVel.Y) > 40 then
        nV = Vector3.new(nV.X, math.min(curV.Y, 50), nV.Z)
        changed = true
    end
    
    if changed then hrp.AssemblyLinearVelocity = nV end
    lastVel = hrp.AssemblyLinearVelocity
end))

Track(UserInputService.JumpRequest:Connect(function()
    if Sys.IJ then
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 50, hrp.AssemblyLinearVelocity.Z) end
    end
end))
Track(RunService.Heartbeat:Connect(function()
    if Sys.IJ then
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp and hrp.AssemblyLinearVelocity.Y < -80 then
            hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, -80, hrp.AssemblyLinearVelocity.Z)
        end
    end
end))

local disR = {}
local rKeys = {"useitem", "combatservice", "ragdoll", "effect"}
local function killR(r)
    if not getconnections or not r:IsA("RemoteEvent") then return end
    if disR[r] then return end
    local nm = r.Name:lower()
    for _, k in ipairs(rKeys) do
        if nm:find(k) then
            disR[r] = {}
            for _, c in ipairs(getconnections(r.OnClientEvent)) do
                if c.Disable then c:Disable() table.insert(disR[r], c) end
            end
            break
        end
    end
end
Track(ReplicatedStorage.DescendantAdded:Connect(function(d)
    if Sys.AE then killR(d) end
end))
local function ToggleAE(state)
    Sys.AE = state
    if state then
        for _, o in ipairs(ReplicatedStorage:GetDescendants()) do killR(o) end
    else
        for r, conns in pairs(disR) do
            for _, c in ipairs(conns) do if c.Enable then c:Enable() end end
        end
        disR = {}
    end
    Save()
end

local origT = {}
local function ToggleXRay(v)
    Sys.XR = v
    if v then
        pcall(function() settings().Rendering.QualityLevel = 1; Lighting.GlobalShadows = false; Lighting.Brightness = 3; Lighting.FogEnd = 9e9 end)
        for _, o in ipairs(Workspace:GetDescendants()) do
            if o:IsA("ParticleEmitter") or o:IsA("Trail") or o:IsA("Beam") then pcall(function() o:Destroy() end)
            elseif o:IsA("BasePart") then
                o.CastShadow = false; o.Material = Enum.Material.Plastic
                if o.Anchored and (o.Name:lower():find("base") or (o.Parent and o.Parent.Name:lower():find("base"))) then
                    origT[o] = o.LocalTransparencyModifier
                    o.LocalTransparencyModifier = 0.85
                end
            end
        end
    else
        for o, t in pairs(origT) do if o then pcall(function() o.LocalTransparencyModifier = t end) end end
        origT = {}
    end
    Save()
end

