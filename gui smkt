local subspaceData = {}
local function getMineOwner(name)
    local oName = name:match("SubspaceTripmine(.+)"); if not oName then return "Unknown" end
    local p = Players:FindFirstChild(oName); return p and p.DisplayName or oName
end
local function ClearSubspaceESP()
    for _,d in pairs(subspaceData) do
        if d.sb then pcall(function() d.sb:Destroy() end) end
        if d.bb then pcall(function() d.bb:Destroy() end) end
    end; subspaceData = {}
end
local function UpdateSubspaceESP()
    if not Sys.SubspaceESP then ClearSubspaceESP() return end
    local folder = Workspace:FindFirstChild("ToolsAdds"); if not folder then return end
    local current = {}
    for _,obj in ipairs(folder:GetChildren()) do
        if obj.Name:match("^SubspaceTripmine") and obj:IsA("BasePart") then
            current[obj] = true
            if not subspaceData[obj] then
                local owner = getMineOwner(obj.Name)
                local sb = Instance.new("SelectionBox"); sb.Name = "ESP_Mine"; sb.Adornee = obj
                sb.Color3 = Color3.fromRGB(200,200,200); sb.LineThickness = 0.05; sb.Parent = obj
                local bb = Instance.new("BillboardGui"); bb.Name = "ESP_MineLabel"; bb.Adornee = obj
                bb.Size = UDim2.new(0,200,0,30); bb.StudsOffset = Vector3.new(0,2.5,0)
                bb.AlwaysOnTop = true; bb.Parent = obj
                local tl = Instance.new("TextLabel", bb); tl.Size = UDim2.new(1,0,1,0)
                tl.BackgroundTransparency = 1; tl.Text = owner.."'s Mine"
                tl.TextColor3 = Color3.fromRGB(200,200,200); tl.Font = Enum.Font.GothamBold; tl.TextSize = 14
                tl.TextStrokeTransparency = 0; tl.TextStrokeColor3 = Color3.new(0,0,0)
                subspaceData[obj] = { sb=sb, bb=bb }
            end
        end
    end
    for obj, d in pairs(subspaceData) do
        if not current[obj] or not obj.Parent then
            if d.sb then pcall(function() d.sb:Destroy() end) end
            if d.bb then pcall(function() d.bb:Destroy() end) end
            subspaceData[obj] = nil
        end
    end
end

