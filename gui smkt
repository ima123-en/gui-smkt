local function abdBlockBuzz()
    pcall(function()
        local bs = LocalPlayer.PlayerScripts:FindFirstChild("Bee", true)
        if bs then local b = bs:FindFirstChild("Buzzing")
            if b and b:IsA("Sound") then b:Stop(); b.Volume = 0 end end
    end)
