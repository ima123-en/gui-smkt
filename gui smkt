-- ============================================================
-- CARPET DESYNC SYSTEM
-- ============================================================
local desyncHook = nil
local function ToggleDesyncHook(state)
    if state then
        if desyncHook then return end
        pcall(function()
            desyncHook = raknet.add_send_hook(function(packet)
                if packet.PacketId == 0x1B then
                    local data = packet.AsBuffer
                    buffer.writeu32(data, 1, 0xFFFFFFFF)
                    packet:SetData(data)
                end
            end)
        end)
        task.spawn(function()
            local char, hum, backpack = LocalPlayer.Character, LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid"), LocalPlayer.Backpack
            if not (char and hum and backpack) then return end
            local carpet = backpack:FindFirstChild("Rainbow Carpet") or backpack:FindFirstChild("Flying Carpet") or char:FindFirstChild("Rainbow Carpet") or char:FindFirstChild("Flying Carpet")
            if carpet then
                hum:EquipTool(carpet)
                task.wait(0)
                carpet:Activate()
                task.wait(0.2)
                hum:UnequipTools()
            end
        end)
    else
        if desyncHook then pcall(function() desyncHook:Disconnect() end) desyncHook = nil end
    end
end

-- ============================================================
-- 🔥 NEW ADVANCED ANTI-RAGDOLL SYSTEM
-- ============================================================
local ragdollConnections = {}
local cachedCharData = {}

local function disconnectAllRagdoll()
    for _, conn in ipairs(ragdollConnections) do
        if typeof(conn) == "RBXScriptConnection" then pcall(function() conn:Disconnect() end) end
    end
    ragdollConnections = {}
end

local function cacheCharacterData()
    local char = LocalPlayer.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return false end
    cachedCharData = { character = char, humanoid = hum, root = root }
    return true
end

local function isRagdolled()
    if not cachedCharData.humanoid then return false end
    local state = cachedCharData.humanoid:GetState()
    if state == Enum.HumanoidStateType.Physics or state == Enum.HumanoidStateType.Ragdoll or state == Enum.HumanoidStateType.FallingDown then return true end
    local endTime = LocalPlayer:GetAttribute("RagdollEndTime")
    if endTime and (endTime - workspace:GetServerTimeNow()) > 0 then return true end
    return false
end

local function antiRagdollLoop()
    while Sys.AR do
        task.wait()
        if isRagdolled() then
            pcall(function()
                for _, descendant in ipairs(cachedCharData.character:GetDescendants()) do
                    if descendant:IsA("BallSocketConstraint") or (descendant:IsA("Attachment") and descendant.Name:find("RagdollAttachment")) then
                        descendant:Destroy()
                    end
                end
                LocalPlayer:SetAttribute("RagdollEndTime", workspace:GetServerTimeNow())
                if cachedCharData.humanoid.Health > 0 then cachedCharData.humanoid:ChangeState(Enum.HumanoidStateType.Running) end
                cachedCharData.root.Anchored = false
                local cam = workspace.CurrentCamera
                if cam and cam.CameraSubject ~= cachedCharData.humanoid then cam.CameraSubject = cachedCharData.humanoid end
            end)
        end
    end
end

local function ToggleAR(enable)
    Sys.AR = enable
    if enable then
        disconnectAllRagdoll()
        if not cacheCharacterData() then return end
        table.insert(ragdollConnections, LocalPlayer.CharacterAdded:Connect(function() task.wait(0.5) if Sys.AR then cacheCharacterData() end end))
        task.spawn(antiRagdollLoop)
    else
        disconnectAllRagdoll()
        cachedCharData = {}
    end
    Save()
end

getgenv().SMKT_DISABLE = function()
    for _, c in pairs(Sys.Conns) do pcall(function() c:Disconnect() end) end
    Sys.Conns = {}
    ToggleDesyncHook(false)
    disconnectAllRagdoll()
    if CoreGui:FindFirstChild("SMKTHub") then CoreGui.SMKTHub:Destroy() end
end

