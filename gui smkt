local function getAnimalHash(al)
    if not al then return "" end
    local h = ""
    for s, d in pairs(al) do
        if type(d) == "table" then
            h = h .. tostring(s) .. tostring(d.Index) .. tostring(d.Mutation)
        end
    end
    return h
end

local function scanSinglePlot(plot)
    pcall(function()
        if isMyBase(plot.Name) then return end
        local ch = Synchronizer:Get(plot.Name)
        if not ch then return end
        local al = ch:Get("AnimalList")
        local hash = getAnimalHash(al)
        if lastAnimalData[plot.Name] == hash then return end
        lastAnimalData[plot.Name] = hash

        for i = #allAnimalsCache, 1, -1 do
            if allAnimalsCache[i].plot == plot.Name then
                table.remove(allAnimalsCache, i)
            end
        end

        local owner = ch:Get("Owner")
        if not owner or not Players:FindFirstChild(owner.Name) then return end
        if not al then return end

        for slot, ad in pairs(al) do
            if type(ad) == "table" then
                if isInFusingMachine(plot, slot) then
                    continue
                end
                local aInfo = AnimalsData[ad.Index]
                if not aInfo then
                    continue
                end
                local mut = ad.Mutation or "None"
                local gv = AnimalsShared:GetGeneration(ad.Index, ad.Mutation, ad.Traits, nil)
                table.insert(allAnimalsCache, {
                    name = aInfo.DisplayName or ad.Index,
                    genValue = gv,
                    genText = formatNumber(gv),
                    mutation = mut,
                    owner = owner.Name,
                    plot = plot.Name,
                    slot = tostring(slot),
                    uid = plot.Name .. "_" .. tostring(slot)
                })
            end
        end

        table.sort(allAnimalsCache, function(a, b)
            return a.genValue > b.genValue
        end)
    end)
end

local function scanAllPlots()
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return end
    for _, p in ipairs(plots:GetChildren()) do
        scanSinglePlot(p)
    end
end

local function GetCachedBrainrotDataByName(name)
    if not name or name == "" then return nil end
    local target = name:lower()
    local best = nil
    for _, a in ipairs(allAnimalsCache) do
        if a.name and a.name:lower() == target and not isMyBase(a.plot) then
            if not best or a.genValue > best.genValue then
                best = a
            end
        end
    end
    return best
end

local function GetHeldBrainrotName()
    local char = LocalPlayer.Character
    if not char then return nil end
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool")
            and t.Name ~= "Flying Carpet"
            and t.Name ~= "Rainbow Carpet"
            and t.Name ~= "Quantum Cloner"
            and t.Name ~= "Bat" then
            return StripRichText(t.Name)
        end
    end
    return nil
end

local function SendWebhook(stolenName)
    if type(WEBHOOK_URL) ~= "string" or WEBHOOK_URL == "" then return end

    stolenName = stolenName or GetHeldBrainrotName() or "a brainrot"
    local cleanFull = StripRichText(stolenName)
    if cleanFull == "" then return end

    local baseName = cleanFull:gsub("%s*%([^)]*%)", "")
    baseName = StripRichText(baseName)
    if baseName == "" then baseName = cleanFull end

    local data = GetCachedBrainrotDataByName(baseName)
    local mutation = data and data.mutation or "None"
    local genText = data and data.genText or "Unknown"
    local owner = data and data.owner or "Unknown"

    if not shouldSendWebhook(baseName, data) then return end

    local mutSuffix = (mutation ~= "None") and (" (" .. mutation .. ")") or ""
    local description = string.format("**%s** stole **%s%s** with **SMKT HUB**!", LocalPlayer.Name, baseName, mutSuffix)

    local embed = {
        title = "Brainrot Steal Detected",
        description = description,
        color = 0x00FF00,
        fields = {
            { name = "Brainrot",       value = baseName, inline = true },
            { name = "Mutation",       value = mutation, inline = true },
            { name = "Generation",     value = genText,  inline = true },
            { name = "Original Owner", value = owner,    inline = true },
        },
        timestamp = DateTime.now():ToIsoDate()
    }

    local payload = { embeds = { embed } }
    local json = HttpService:JSONEncode(payload)

    task.spawn(function()
        local req = getRequestFunc()
        if req then
            pcall(function()
                req({
                    Url = WEBHOOK_URL,
                    Method = "POST",
                    Headers = { ["Content-Type"] = "application/json" },
                    Body = json
                })
            end)
        else
            pcall(function()
                HttpService:PostAsync(WEBHOOK_URL, json, Enum.HttpContentType.ApplicationJson)
            end)
        end
    end)
end

