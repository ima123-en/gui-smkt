-- ============================================================
-- ORIGINAL ANTI-KNOCKBACK (preserved)
-- ============================================================
local isJmp, lastVel = false, Vector3.zero
Track(RunService.Heartbeat:Connect(function()
    if not Sys.AK then return end
    local c = LocalPlayer.Character; local hrp = c and c:FindFirstChild("HumanoidRootPart"); local h = c and c:FindFirstChild("Humanoid")
    if not hrp or not h then return end
    local st = h:GetState()
    local curV = hrp.AssemblyLinearVelocity
    if st == Enum.HumanoidStateType.Jumping then isJmp = true lastVel = curV return
    elseif st == Enum.HumanoidStateType.Landed or st == Enum.HumanoidStateType.Running then isJmp = false end
    local nV = curV; local changed = false; local flatV = Vector3.new(curV.X, 0, curV.Z)
    if flatV.Magnitude > 60 then local u = flatV.Unit nV = Vector3.new(u.X * 60, nV.Y, u.Z * 60) changed = true end
    if not isJmp and st ~= Enum.HumanoidStateType.Freefall and curV.Y > 50 then nV = Vector3.new(nV.X, 50, nV.Z) changed = true end
    if st == Enum.HumanoidStateType.Freefall and not isJmp and (curV.Y - lastVel.Y) > 40 then nV = Vector3.new(nV.X, math.min(curV.Y, 50), nV.Z) changed = true end
    if changed then hrp.AssemblyLinearVelocity = nV end lastVel = hrp.AssemblyLinearVelocity
end))

