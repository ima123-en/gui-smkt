local arV2Conns = {}
local arV2Scheduled = false

local function cleanRagV2(char)
    if not char then return end
    local carpetEq = false
    pcall(function()
        local t = char:FindFirstChild("Flying Carpet") or char:FindFirstChild("Rainbow Carpet")
        if t then
            local h = char:FindFirstChild("HumanoidRootPart")
            if h then
                for _, o in ipairs(h:GetChildren()) do
                    if o:IsA("BodyVelocity") or o:IsA("BodyPosition") or o:IsA("BodyGyro") then
                        carpetEq = true
                        break
                    end
                end
            end
        end
    end)
    for _, d in ipairs(char:GetDescendants()) do
        if d:IsA("BallSocketConstraint") or d:IsA("NoCollisionConstraint") or d:IsA("HingeConstraint") or (d:IsA("Attachment") and (d.Name == "A" or d.Name == "B")) then
            d:Destroy()
        elseif (d:IsA("BodyVelocity") or d:IsA("BodyPosition") or d:IsA("BodyGyro")) and not carpetEq then
            d:Destroy()
        end
    end
    for _, d in ipairs(char:GetDescendants()) do
        if d:IsA("Motor6D") then
            d.Enabled = true
        end
    end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        local a = hum:FindFirstChild("Animator")
        if a then
            for _, t in ipairs(a:GetPlayingAnimationTracks()) do
                local n = t.Animation and t.Animation.Name:lower() or ""
                if n:find("rag") or n:find("fall") or n:find("hurt") or n:find("down") then
                    t:Stop(0)
                end
            end
        end
    end
    task.defer(function()
        pcall(function()
            local pm = LocalPlayer:FindFirstChild("PlayerScripts")
            if pm then pm = pm:FindFirstChild("PlayerModule") end
            if pm then
                require(pm):GetControls():Enable()
            end
        end)
    end)
end

local function cleanRagV2D(char)
    if arV2Scheduled then return end
    arV2Scheduled = true
    task.defer(function()
        arV2Scheduled = false
        if char and char.Parent then
            cleanRagV2(char)
        end
    end)
end

local function isRagDesc(o)
    return o:IsA("BallSocketConstraint")
        or o:IsA("NoCollisionConstraint")
        or o:IsA("HingeConstraint")
        or (o:IsA("Attachment") and (o.Name == "A" or o.Name == "B"))
        or o:IsA("BodyVelocity")
        or o:IsA("BodyPosition")
        or o:IsA("BodyGyro")
end

local function hookARV2(char)
    for _, c in ipairs(arV2Conns) do
        pcall(function()
            c:Disconnect()
        end)
    end
    arV2Conns = {}
    local hum = char:WaitForChild("Humanoid", 10)
    local hrp = char:WaitForChild("HumanoidRootPart", 10)
    if not hum or not hrp then return end
    local lastVel = Vector3.zero
    local isBoosting = false

    table.insert(arV2Conns, hum.StateChanged:Connect(function()
        local st = hum:GetState()
        if st == Enum.HumanoidStateType.Physics or st == Enum.HumanoidStateType.Ragdoll or st == Enum.HumanoidStateType.FallingDown or st == Enum.HumanoidStateType.GettingUp then
            local ca = false
            pcall(function()
                local t = char:FindFirstChild("Flying Carpet") or char:FindFirstChild("Rainbow Carpet")
                if t and hrp then
                    for _, o in ipairs(hrp:GetChildren()) do
                        if o:IsA("BodyVelocity") or o:IsA("BodyPosition") or o:IsA("BodyGyro") then
                            ca = true
                        end
                    end
                end
            end)
            if not ca then
                hum:ChangeState(Enum.HumanoidStateType.Running)
            end
            cleanRagV2(char)
            pcall(function()
                workspace.CurrentCamera.CameraSubject = hum
            end)
            if Sys.ReenableDesyncOnRag and Sys.CD then
                ReenableDesyncOnce()
            end
        end
    end))

    table.insert(arV2Conns, char.DescendantAdded:Connect(function(d)
        if isRagDesc(d) then
            cleanRagV2D(char)
        end
    end))

    table.insert(arV2Conns, RunService.Heartbeat:Connect(function()
        if getgenv().SMKT_DISABLE_VELOCITY then
            lastVel = hrp.AssemblyLinearVelocity
            return
        end
        local st = hum:GetState()
        if st == Enum.HumanoidStateType.Physics or st == Enum.HumanoidStateType.Ragdoll or st == Enum.HumanoidStateType.FallingDown or st == Enum.HumanoidStateType.GettingUp then
            cleanRagV2(char)
            local vel = hrp.AssemblyLinearVelocity
            if (vel - lastVel).Magnitude > 40 and vel.Magnitude > 25 then
                hrp.AssemblyLinearVelocity = vel.Unit * math.min(vel.Magnitude, 15)
            end
            if not isBoosting then
                isBoosting = true
                hum.WalkSpeed = 400
            end
        else
            if isBoosting then
                isBoosting = false
                hum.WalkSpeed = 16
            end
        end
        lastVel = hrp.AssemblyLinearVelocity
    end))

    cleanRagV2(char)
end

