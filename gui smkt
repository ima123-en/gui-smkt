local function ToggleAntiBee(enable)
    Sys.ABD = enable
    if enable then
        if abdState.running then return end; abdState.running = true
        for _,i in ipairs(Lighting:GetDescendants()) do abdNuke(i) end
        local c1 = Lighting.DescendantAdded:Connect(function(o) if abdState.running then abdNuke(o) end end)
        table.insert(abdState.conns, c1); Track(c1)
        local c2 = RunService.Heartbeat:Connect(function() if abdState.running then abdBlockBuzz() end end)
        table.insert(abdState.conns, c2); Track(c2)
        pcall(function()
            local pm = LocalPlayer:FindFirstChild("PlayerScripts")
            if pm then pm = pm:FindFirstChild("PlayerModule") end
            if pm then local Controls = require(pm):GetControls()
                if Controls then
                    abdState.origMove = Controls.moveFunction
                    local function pMove(s,mv,rc) if abdState.origMove then abdState.origMove(s,mv,rc) end end
                    local c3 = RunService.Heartbeat:Connect(function()
                        if abdState.running and Controls.moveFunction ~= pMove then Controls.moveFunction = pMove end end)
                    table.insert(abdState.conns, c3); Track(c3); Controls.moveFunction = pMove
                end
            end
        end)
    else
        abdState.running = false
        for _,c in ipairs(abdState.conns) do pcall(function() c:Disconnect() end) end; abdState.conns = {}
        pcall(function()
            if abdState.origMove then
                local pm = LocalPlayer:FindFirstChild("PlayerScripts")
                if pm then pm = pm:FindFirstChild("PlayerModule") end
                if pm then local C = require(pm):GetControls(); if C then C.moveFunction = abdState.origMove end end
            end
        end)
    end; Save()
end

