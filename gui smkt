-- ============================================================
local function hasExclamation(target)
    for _,d in ipairs(target:GetDescendants()) do
        if d:IsA("BillboardGui") then
            local l = d:FindFirstChildWhichIsA("TextLabel", true)
            if l and l.Text:find("!") then return true end
        end
    end; return false
end
local function applyTurretVis(target)
    for _,d in ipairs(target:GetDescendants()) do
        if d:IsA("BasePart") and d ~= target then d.Transparency=0.5; d.CanCollide=false; d.CanTouch=false; d.CanQuery=false
        elseif d:IsA("BillboardGui") and d.Name ~= "SentryLabel" then d:Destroy()
        elseif d:IsA("Decal") or d:IsA("Texture") then d.Transparency=0.5 end
    end
    if target:IsA("BasePart") and target.Name ~= "ProxyVisual" then target.Transparency=1; target.CanCollide=false end
end
local function getClosestSentry()
    local ch = LocalPlayer.Character; local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local closest, dist = nil, math.huge
    for _,inst in ipairs(Workspace:GetDescendants()) do
        if inst.Name:match("^Sentry_") and hasExclamation(inst) then
            local r = inst:IsA("BasePart") and inst or inst:FindFirstChildWhichIsA("BasePart",true)
            if r then local d = (hrp.Position-r.Position).Magnitude; if d < dist then dist=d; closest=inst end end
        end
    end; return closest
end

task.spawn(function()
    while true do
        if Sys.ADT and not (LocalPlayer:GetAttribute("Stealing") == true) then
            local sentry = getClosestSentry()
            if sentry then
                while sentry and sentry.Parent and (LocalPlayer:GetAttribute("Stealing") ~= true) and Sys.ADT do
                    local ch = LocalPlayer.Character; local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
                    local hum = ch and ch:FindFirstChildOfClass("Humanoid")
                    if not hrp or not hum then break end
                    local bat = LocalPlayer.Backpack:FindFirstChild("Bat") or ch:FindFirstChild("Bat")
                    applyTurretVis(sentry)
                    local off = hrp.CFrame.LookVector * 4
                    local cf = CFrame.new(hrp.Position + off, hrp.Position)
                    if sentry:IsA("Model") then sentry:PivotTo(cf) elseif sentry:IsA("BasePart") then sentry.CFrame = cf end
                    if bat then if bat.Parent ~= ch then hum:EquipTool(bat) end; bat:Activate() end
                    task.wait(0.1); if not hasExclamation(sentry) then break end
                end
            end
        end; task.wait(0.1)
    end
end)

