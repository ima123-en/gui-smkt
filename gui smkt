local waitingForKeyVar = nil

local function CTGuiToggle(parent, name, yPos, stateVar, cb, kbVar)
    local h = Instance.new("Frame", parent)
    h.Size = UDim2.new(1, 0, 0, 38)
    h.Position = UDim2.new(0, 0, 0, yPos)
    h.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
    Instance.new("UICorner", h).CornerRadius = UDim.new(0, 8)

    local l = Instance.new("TextLabel", h)
    l.Size = UDim2.new(0, 140, 1, 0)
    l.Position = UDim2.new(0, 12, 0, 0)
    l.BackgroundTransparency = 1
    l.Text = name
    l.Font = Enum.Font.Gotham
    l.TextSize = 12
    l.TextColor3 = Sys[stateVar] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 190)
    l.TextXAlignment = Enum.TextXAlignment.Left

    if kbVar then
        local kb = Instance.new("TextButton", h)
        kb.Size = UDim2.new(0, 36, 0, 22)
        kb.Position = UDim2.new(1, -100, 0.5, -11)
        kb.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
        kb.Text = Sys[kbVar] or ""
        kb.Font = Enum.Font.GothamBold
        kb.TextSize = 10
        kb.TextColor3 = Color3.fromRGB(200, 200, 210)
        Instance.new("UICorner", kb).CornerRadius = UDim.new(0, 6)
        kb.MouseButton1Click:Connect(function()
            waitingForKeyVar = kbVar
            kb.Text = "..."
        end)
        Track(UserInputService.InputBegan:Connect(function(i, g)
            if g then return end
            if waitingForKeyVar and i.UserInputType == Enum.UserInputType.Keyboard then
                local kn = i.KeyCode.Name
                if kn and kn ~= "Unknown" then
                    Sys[waitingForKeyVar] = kn
                    if waitingForKeyVar == "CarpetSpeedKey" then
                        carpetSpeedKeyCode = i.KeyCode
                    elseif waitingForKeyVar == "CarpetDesyncKey" then
                        carpetDesyncKeyCode = i.KeyCode
                    end
                    Save()
                    kb.Text = kn
                else
                    kb.Text = Sys[waitingForKeyVar] or ""
                end
                waitingForKeyVar = nil
            end
        end))
        kb.Text = Sys[kbVar] or (kbVar == "CarpetSpeedKey" and "Q" or (kbVar == "CarpetDesyncKey" and "G" or ""))
    end

    local bg = Instance.new("Frame", h)
    bg.Size = UDim2.new(0, 42, 0, 22)
    bg.Position = UDim2.new(1, -54, 0.5, -11)
    bg.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

    local c = Instance.new("Frame", bg)
    c.Size = UDim2.new(0, 16, 0, 16)
    c.Position = Sys[stateVar] and UDim2.new(0, 23, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
    c.BackgroundColor3 = Sys[stateVar] and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(120, 120, 120)
    Instance.new("UICorner", c).CornerRadius = UDim.new(1, 0)

    local btn = Instance.new("TextButton", h)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""

    local function uv(st)
        TweenService:Create(c, TweenInfo.new(0.2), {
            Position = st and UDim2.new(0, 23, 0.5, -8) or UDim2.new(0, 3, 0.5, -8),
            BackgroundColor3 = st and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(120, 120, 120)
        }):Play()
        TweenService:Create(l, TweenInfo.new(0.2), {
            TextColor3 = st and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 190)
        }):Play()
    end

    btn.MouseButton1Click:Connect(function()
        Sys[stateVar] = not Sys[stateVar]
        uv(Sys[stateVar])
        cb(Sys[stateVar])
    end)

    return uv
end

