local StealPatterns = {
    "you stole",
    "you have stolen"
}
local lastStealKey, lastStealTime = nil, 0

local function extractItem(txt, pattern)
    local plain = StripRichText(txt)
    local l = plain:lower()
    local idx = l:find(pattern)
    if idx then
        local raw = plain:sub(idx + #pattern)
        raw = raw:gsub(" from you.*", ""):gsub("[!%.]", "")
        raw = StripRichText(raw)
        return raw
    end
    return nil
end

local function HandleStealText(txt)
    if type(txt) ~= "string" or txt == "" then return end
    local plain = StripRichText(txt)
    if plain == "" then return end
    local l = plain:lower()

    local matched = false
    local item = nil
    for _, pat in ipairs(StealPatterns) do
        if l:find(pat) then
            matched = true
            item = extractItem(plain, pat .. " ")
            break
        end
    end
    if not matched then return end

    local key = (item and item ~= "" and item:lower()) or l
    if lastStealKey == key and (tick() - lastStealTime) < 2 then
        return
    end
    lastStealKey = key
    lastStealTime = tick()

    task.spawn(function()
        scanAllPlots()
        task.wait(0.1)
        SendWebhook(item)
    end)
end

local function HookUIForSteal(obj)
    if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
        HandleStealText(obj.Text)
