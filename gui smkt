local function CreateToggle(name, yPos, stateVar, cb)
    local h = Instance.new("Frame", MainPanel)
    h.Size = UDim2.new(0.9, 0, 0, 38)
    h.Position = UDim2.new(0.05, 0, 0, yPos)
    h.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
    Instance.new("UICorner", h).CornerRadius = UDim.new(0, 8)

    local l = Instance.new("TextLabel", h)
    l.Size = UDim2.new(0.65, 0, 1, 0)
    l.Position = UDim2.new(0, 14, 0, 0)
    l.BackgroundTransparency = 1
    l.Text = name
    l.Font = Enum.Font.Gotham
    l.TextSize = 13
    l.TextColor3 = Sys[stateVar] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 190)
    l.TextXAlignment = Enum.TextXAlignment.Left

    local bg = Instance.new("Frame", h)
    bg.Size = UDim2.new(0, 42, 0, 22)
    bg.Position = UDim2.new(1, -54, 0.5, -11)
    bg.BackgroundColor3 = Sys[stateVar] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(35, 35, 40)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

    local c = Instance.new("Frame", bg)
    c.Size = UDim2.new(0, 16, 0, 16)
    c.Position = Sys[stateVar] and UDim2.new(0, 23, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
    c.BackgroundColor3 = Sys[stateVar] and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(80, 80, 90)
    Instance.new("UICorner", c).CornerRadius = UDim.new(1, 0)

    local btn = Instance.new("TextButton", h)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""

    btn.MouseButton1Click:Connect(function()
        Sys[stateVar] = not Sys[stateVar]
        local st = Sys[stateVar]
        
        local pos = st and UDim2.new(0, 23, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
        local col = st and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(80, 80, 90)
        local bgc = st and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(35, 35, 40)
        local txtc = st and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 190)

        TweenService:Create(c, TweenInfo.new(0.2), {Position = pos, BackgroundColor3 = col}):Play()
        TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3 = bgc}):Play()
        TweenService:Create(l, TweenInfo.new(0.2), {TextColor3 = txtc}):Play()
        
        cb(st)
        Save()
    end)
end

