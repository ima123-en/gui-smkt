-- ============================================================
-- CARPET DESYNC SYSTEM
-- ============================================================
local desyncHook = nil
local function ToggleDesyncHook(state)
    if state then
        if desyncHook then return end
        pcall(function()
            desyncHook = raknet.add_send_hook(function(packet)
                if packet.PacketId == 0x1B then
                    local data = packet.AsBuffer
                    buffer.writeu32(data, 1, 0xFFFFFFFF)
                    packet:SetData(data)
                end
            end)
        end)
        task.spawn(function()
            local char, hum, backpack = LocalPlayer.Character, LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid"), LocalPlayer.Backpack
            if not (char and hum and backpack) then return end
            local carpet = backpack:FindFirstChild("Rainbow Carpet") or backpack:FindFirstChild("Flying Carpet") or char:FindFirstChild("Rainbow Carpet") or char:FindFirstChild("Flying Carpet")
            if carpet then
                hum:EquipTool(carpet)
                task.wait(0)
                carpet:Activate()
                task.wait(0.2)
                hum:UnequipTools()
            end
        end)
    else
        if desyncHook then pcall(function() desyncHook:Disconnect() end) desyncHook = nil end
    end
end

getgenv().SMKT_DISABLE = function()
    for _, c in pairs(Sys.Conns) do pcall(function() c:Disconnect() end) end
    Sys.Conns = {}
    ToggleDesyncHook(false)
    if CoreGui:FindFirstChild("SMKTHub") then CoreGui.SMKTHub:Destroy() end
end

-- ============================================================
-- ANTI RAGDOLL & OTHER PROTECTIONS (No changes here)
-- ============================================================
local ragConns = {}
local lastVelAR = Vector3.new()
local function ragClean(char)
    if not char then char = LocalPlayer.Character end; if not char then return end
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BallSocketConstraint") or v:IsA("HingeConstraint") or v:IsA("NoCollisionConstraint") then pcall(function() v:Destroy() end)
        elseif v:IsA("Motor6D") then v.Enabled = true end
    end
end
local function startAntiRagdoll()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end
    table.insert(ragConns, hum.StateChanged:Connect(function(_, new)
        if not Sys.AR then return end
        if new == Enum.HumanoidStateType.Ragdoll or new == Enum.HumanoidStateType.FallingDown or new == Enum.HumanoidStateType.Physics then hum:ChangeState(Enum.HumanoidStateType.Running) ragClean(char) end
    end))
    for _, c in pairs(ragConns) do Track(c) end
end
local function ToggleAR(state) Sys.AR = state if state then startAntiRagdoll() else for _, c in pairs(ragConns) do c:Disconnect() end ragConns = {} end Save() end

