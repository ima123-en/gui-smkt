local function ToggleAntiBee(enable)
    Sys.ABD = enable
    if enable then
        if abdState.running then return end
        abdState.running = true

        for _, i in ipairs(Lighting:GetDescendants()) do
            abdNuke(i)
        end
        local c1 = Lighting.DescendantAdded:Connect(function(o)
            if abdState.running then
                abdNuke(o)
            end
        end)
        table.insert(abdState.conns, c1)
        Track(c1)

        local c2 = RunService.Heartbeat:Connect(function()
            if abdState.running then
                abdBlockBuzz()
            end
        end)
        table.insert(abdState.conns, c2)
        Track(c2)

        pcall(function()
            local pm = LocalPlayer:FindFirstChild("PlayerScripts")
            if pm then pm = pm:FindFirstChild("PlayerModule") end
            if pm then
                local Controls = require(pm):GetControls()
                if Controls then
                    abdState.origMove = Controls.moveFunction
                    local function pMove(s, mv, rc)
                        if abdState.origMove then
                            abdState.origMove(s, mv, rc)
                        end
                    end
                    local c3 = RunService.Heartbeat:Connect(function()
                        if abdState.running and Controls.moveFunction ~= pMove then
                            Controls.moveFunction = pMove
                        end
                    end)
                    table.insert(abdState.conns, c3)
                    Track(c3)
                    Controls.moveFunction = pMove
                end
            end
        end)

        abdOrigFOV = workspace.CurrentCamera and workspace.CurrentCamera.FieldOfView or 70
        abdCamConn = RunService.RenderStepped:Connect(function()
            local cam = workspace.CurrentCamera
            if cam then
                cam.FieldOfView = abdOrigFOV
            end
        end)
        table.insert(abdState.conns, abdCamConn)
        Track(abdCamConn)
    else
        abdState.running = false
        for _, c in ipairs(abdState.conns) do
            pcall(function()
                c:Disconnect()
            end)
        end
        abdState.conns = {}
        pcall(function()
            if abdState.origMove then
                local pm = LocalPlayer:FindFirstChild("PlayerScripts")
                if pm then pm = pm:FindFirstChild("PlayerModule") end
                if pm then
                    local C = require(pm):GetControls()
                    if C then
                        C.moveFunction = abdState.origMove
                    end
                end
            end
        end)
        if abdCamConn then
            abdCamConn:Disconnect()
            abdCamConn = nil
        end
        local cam = workspace.CurrentCamera
        if cam and abdOrigFOV then
            cam.FieldOfView = abdOrigFOV
        end
        abdOrigFOV = nil
    end
    Save()
end

local function hasExclamation(target)
    for _, d in ipairs(target:GetDescendants()) do
        if d:IsA("BillboardGui") then
            local l = d:FindFirstChildWhichIsA("TextLabel", true)
            if l and l.Text:find("!") then
                return true
            end
        end
    end
    return false
end

local function applyTurretVis(target)
    for _, d in ipairs(target:GetDescendants()) do
        if d:IsA("BasePart") and d ~= target then
            d.Transparency = 0.5
            d.CanCollide = false
            d.CanTouch = false
            d.CanQuery = false
        elseif d:IsA("BillboardGui") and d.Name ~= "SentryLabel" then
            d:Destroy()
        elseif d:IsA("Decal") or d:IsA("Texture") then
            d.Transparency = 0.5
        end
    end
    if target:IsA("BasePart") and target.Name ~= "ProxyVisual" then
        target.Transparency = 1
        target.CanCollide = false
    end
end

local function getClosestSentry()
    local ch = LocalPlayer.Character
    local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local closest, dist = nil, math.huge
    for _, inst in ipairs(Workspace:GetDescendants()) do
        if inst.Name:match("^Sentry_") and hasExclamation(inst) then
            local r = inst:IsA("BasePart") and inst or inst:FindFirstChildWhichIsA("BasePart", true)
            if r then
                local d = (hrp.Position - r.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = inst
                end
            end
        end
    end
    return closest
end

local function triggerClosestUnlock(yLevel, maxY)
    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local playerY = yLevel or hrp.Position.Y
    local Y_THRESHOLD = 5

    local bestPromptSameLevel = nil
    local shortestDistSameLevel = math.huge

    local bestPromptFallback = nil
    local shortestDistFallback = math.huge

    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return end

    for _, obj in ipairs(plots:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.Enabled then
            local part = obj.Parent
            if part and part:IsA("BasePart") then
                if maxY and part.Position.Y > maxY then
                else
                    local distance = (hrp.Position - part.Position).Magnitude
                    local yDifference = math.abs(playerY - part.Position.Y)

                    if distance < shortestDistFallback then
                        shortestDistFallback = distance
                        bestPromptFallback = obj
                    end

                    if yDifference <= Y_THRESHOLD then
                        if distance < shortestDistSameLevel then
                            shortestDistSameLevel = distance
                            bestPromptSameLevel = obj
                        end
                    end
                end
            end
        end
    end

    local targetPrompt = bestPromptSameLevel or bestPromptFallback

    if targetPrompt then
        if fireproximityprompt then
            fireproximityprompt(targetPrompt)
        else
            targetPrompt:InputBegan(Enum.UserInputType.MouseButton1)
            task.wait(0.05)
            targetPrompt:InputEnded(Enum.UserInputType.MouseButton1)
        end
    end
end

