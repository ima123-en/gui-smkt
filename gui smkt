local function setScaleUI(norm)
    norm = math.clamp(norm, 0.2, 1)
    Sys.GuiScale = norm
    uiScale.Scale = norm
    local pct = math.floor(norm * 100 + 0.5)
    scaleInput.Text = tostring(pct)
    barFill.Size = UDim2.new(norm, 0, 1, 0)
    knob.Position = UDim2.new(norm, 0, 0.5, 0)
end

local function applyPercentInput()
    local txt = scaleInput.Text or ""
    txt = txt:gsub("%%", ""):gsub("%s+", "")
    local num = tonumber(txt)
    if not num then
        setScaleUI(Sys.GuiScale or 1)
        return
    end
    num = math.clamp(num, 20, 100)
    local norm = num / 100
    setScaleUI(norm)
    Save()
end

scaleInput.FocusLost:Connect(function()
    applyPercentInput()
end)

scaleInput.Focused:Connect(function()
    draggingScale = false
end)

setScaleUI(Sys.GuiScale or 1)

barBg.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingScale = true
        local mouseX = UserInputService:GetMouseLocation().X
        local rel = math.clamp(mouseX - barBg.AbsolutePosition.X, 0, barBg.AbsoluteSize.X)
        local norm = rel / barBg.AbsoluteSize.X
        setScaleUI(norm)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingScale and input.UserInputType == Enum.UserInputType.MouseMovement then
        local mouseX = UserInputService:GetMouseLocation().X
        local rel = math.clamp(mouseX - barBg.AbsolutePosition.X, 0, barBg.AbsoluteSize.X)
        local norm = rel / barBg.AbsoluteSize.X
        setScaleUI(norm)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        if draggingScale then
            draggingScale = false
            Save()
        end
    end
end)

