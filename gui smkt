local abdState = { running = false, conns = {}, origMove = nil,
    badNames = { Blue=true, DiscoEffect=true, BeeBlur=true, ColorCorrection=true } }

local function abdNuke(obj)
    if obj and obj.Parent and abdState.badNames[obj.Name] then pcall(function() obj:Destroy() end) end
