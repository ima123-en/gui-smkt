local function EnableFPSBoost()
    if fpsBoostEnabled then return end
    fpsBoostEnabled = true

    local a = RunService
    local b = Lighting
    local c = UserSettings():GetService("UserGameSettings")

    c.SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1
    workspace.LevelOfDetail = Enum.ModelLevelOfDetail.Disabled
    b.Technology = Enum.Technology.Compatibility
    b.GlobalShadows = false
    b.Brightness = 1
    b.FogEnd = 9e9

    for _, e in ipairs(b:GetChildren()) do
        if e:IsA("PostEffect") then
            e.Enabled = false
        elseif e:IsA("Atmosphere") then
            e.Density = 0
            e.Offset = 0
            e.Haze = 0
            e.Glare = 0
            e.Color = Color3.new(0, 0, 0)
        elseif e:IsA("Sky") then
            e.CelestialBodiesShown = false
        end
    end

    b.ChildAdded:Connect(function(d)
        if d:IsA("PostEffect") then
            d.Enabled = false
        elseif d:IsA("Atmosphere") then
            d.Density = 0
            d.Haze = 0
            d.Glare = 0
        elseif d:IsA("Sky") then
            d.CelestialBodiesShown = false
        end
    end)

    local types = {
        "ParticleEmitter",
        "Fire",
        "Smoke",
        "Sparkles",
        "Trail",
        "Beam",
        "SelectionBox",
        "SelectionSphere"
    }

    local function isEffect(e)
        for _, g in ipairs(types) do
            if e:IsA(g) then
                return true
            end
        end
        return false
    end

    local function disableEffect(e)
        if e:IsA("SelectionBox") or e:IsA("SelectionSphere") then
            e.Color3 = Color3.new(0, 0, 0)
        else
            if e:IsA("ParticleEmitter") or e:IsA("Trail") or e:IsA("Beam") or e:IsA("Fire") or e:IsA("Smoke") or e:IsA("Sparkles") then
                e.Enabled = false
            end
        end
    end

    for _, f in ipairs(workspace:GetDescendants()) do
        if isEffect(f) then
            disableEffect(f)
        end
    end

    workspace.DescendantAdded:Connect(function(e)
        if isEffect(e) then
            disableEffect(e)
        end
    end)

    local function removeShadow(e)
        if e:IsA("BasePart") then
            e.CastShadow = false
        end
    end

    for _, f in ipairs(workspace:GetDescendants()) do
        removeShadow(f)
    end

    workspace.DescendantAdded:Connect(function(e)
        removeShadow(e)
    end)

    local function removeSurface(e)
        if e:IsA("SurfaceAppearance") then
            e:Destroy()
        end
    end

    for _, f in ipairs(workspace:GetDescendants()) do
        removeSurface(f)
    end

    workspace.DescendantAdded:Connect(function(e)
        removeSurface(e)
    end)

    local function applyCameraSettings(f)
        if f then
            f.FieldOfView = 70
            f.CameraType = Enum.CameraType.Custom
        end
    end

    applyCameraSettings(workspace.CurrentCamera)
    workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
        applyCameraSettings(workspace.CurrentCamera)
    end)

    local threshold = 0.15
    a.Heartbeat:Connect(function(dt)
        if dt > threshold then
            task.wait()
        end
    end)
end

local function StopAnimationsOnInstance(inst)
    if inst:IsA("Animator") or inst:IsA("Humanoid") or inst:IsA("AnimationController") then
        local animator = inst
        if not inst:IsA("Animator") then
            animator = inst:FindFirstChildOfClass("Animator") or inst
        end
        if animator then
            pcall(function()
                for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                    track:Stop()
                end
            end)
            if animator.AnimationPlayed then
                animator.AnimationPlayed:Connect(function(track)
                    track:Stop()
                end)
            end
        end
    end
end

local function DisableAllAnimations()
    if noAnimationsEnabled then return end
    noAnimationsEnabled = true
    for _, d in ipairs(workspace:GetDescendants()) do
        StopAnimationsOnInstance(d)
    end
    workspace.DescendantAdded:Connect(function(d)
        StopAnimationsOnInstance(d)
    end)
end

