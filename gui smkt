    local btn = Instance.new("TextButton", h)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""

    local function set(on)
        TweenService:Create(bg, TweenInfo.new(0.15), {
            BackgroundColor3 = on and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(35, 35, 40)
        }):Play()
        TweenService:Create(t, TweenInfo.new(0.15), {
            TextColor3 = on and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(180, 180, 190)
        }):Play()
        TweenService:Create(l, TweenInfo.new(0.15), {
            TextColor3 = on and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 190)
        }):Play()
    end

    return {Button = btn, Set = set}
end

