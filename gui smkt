Track(UserInputService.InputBegan:Connect(function(i, g)
    if g then return end
    if i.UserInputType == Enum.UserInputType.Keyboard then
        local k = i.KeyCode
        if k == carpetSpeedKeyCode then
            Sys.CS = not Sys.CS
            setCarpetSpeed(Sys.CS)
            if csUpd then
                csUpd(Sys.CS)
            end
            Save()
        elseif k == carpetDesyncKeyCode then
            ToggleDesyncHook(not Sys.CD)
            Save()
        end
    end
end))

